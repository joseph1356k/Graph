# ==========================================================================
# Miracle — ejemplo de variables de entorno. Copia a .env y rellena.
#   cp .env.example .env
# ==========================================================================

# --- Neo4j (REQUERIDO: el servidor no arranca sin NEO4J_URI) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# --- OpenAI (voz en tiempo real / transcripción) ---
OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin
# Modelo de transcripción. Default: gpt-4o-mini-transcribe (rápido y económico).
# Si priorizas precisión en nombres/números sobre velocidad, cambia a gpt-4o-transcribe.
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Prompt de sesgo para la transcripción (vocabulario clínico, nombres hispanos, cédulas, etc.).
# Déjalo vacío para usar el default en español del código, o ponlo aquí para afinarlo.
# OPENAI_REALTIME_TRANSCRIPTION_PROMPT=
# Silencio (ms) que el VAD espera antes de cerrar un turno. Subido a 1100 para dictado pausado
# de números; súbelo más (1300-1500) si te corta a media cédula/teléfono.
# OPENAI_REALTIME_VAD_SILENCE_MS=1100

# --- Deepgram (opcional, transporte de voz alternativo) ---
# DEEPGRAM_API_KEY=

# --- Azure Foundry (opcional, reemplaza OpenRouter/OpenAI para dynamic fill y matching) ---
# Usa el endpoint OpenAI-compatible base, por ejemplo:
# AZURE_FOUNDRY_BASE_URL=https://christian-maldonadoor-0222-resou.services.ai.azure.com/openai/v1
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_MODEL=DeepSeek-V4-Flash

# --- Miracle sidecar (dictado/integracion medica externa) ---
# MIRACLE_MEDICAL_ENGINE_URL=http://127.0.0.1:8766
# MIRACLE_BASE_URL=http://127.0.0.1:8766
# En Vercel no hay fallback a Render. Si necesitas dictado Miracle externo,
# configura un motor HTTP propio y pasalo de forma explicita.
# Uso central IA: Miracle puede reportar consumo de OpenAI a Graph con esta clave compartida.
# GRAPH_USAGE_INGEST_KEY=
# Gateway persistente para WebSocket/telefono cuando la web corre en Vercel.
# VOICE_GATEWAY_URL=https://graph-1-hap6.onrender.com

# --- Autenticacion (local, sin proveedor externo) ---
# Login de administrador para el dashboard/extension (usuario:usuario,otro:otro).
LOCAL_ADMIN_USERS=
LOCAL_ADMIN_PASSWORD=
# Secreto para firmar las sesiones de administrador. Si se omite, se genera uno
# aleatorio por proceso (las sesiones no sobreviven un reinicio del servidor).
LOCAL_ADMIN_SECRET=
# Modo invitado para paginas de demo publicas (sin login). Seguro de activar en
# produccion si quieres permitir acceso anonimo a las paginas de demo.
ALLOW_LOCAL_ANONYMOUS=false
# Bypass temporal y reversible para avanzar el desarrollo sin login.
# Mantenerlo en false por defecto y activarlo solo mientras se depura localmente.
TEMPORARY_DISABLE_AUTH=false
# Secreto compartido entre Node y el runtime Python (bounded/miracle-ai) para
# autenticar las llamadas internas al sidecar de voz/nota. Opcional en local.
GRAPH_INTERNAL_TOKEN=

# --- Servidor ---
NODE_ENV=development
PORT=3000
# PUBLIC_BASE_URL=   # URL pública si despliegas detrás de un dominio/túnel
# CORS: orígenes permitidos separados por coma. Vacío = permisivo (solo dev).
ALLOWED_ORIGINS=

# --- Workflows y administracion ---
GLOBAL_WORKFLOW_ADMIN_EMAILS=
ALLOW_LOCAL_GLOBAL_WORKFLOW_ADMIN=false
