# ==========================================================================
# Miracle — ejemplo de variables de entorno. Copia a .env y rellena.
#   cp .env.example .env
# ==========================================================================

# --- Neo4j (REQUERIDO: el servidor no arranca sin NEO4J_URI) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# --- OpenAI (LLM para dynamic fill / matching) ---
OPENAI_API_KEY=

# --- Deepgram (STT canónico para transcripción de voz) ---
# DEEPGRAM_API_KEY=

# --- Soniox (STT en streaming alternativo, modelo stt-rt-v5) ---
# Selecciona el proveedor con MIRACLE_STT_PROVIDER=soniox (o desde Provider Studio).
# SONIOX_API_KEY=
# MIRACLE_SONIOX_ENDPOINT_DELAY_MS=2000   # 500-3000, retardo max de endpointing
# MIRACLE_SONIOX_TOKEN_TTL_SECONDS=60     # TTL de la clave temporal (10-3600)
# Especialización médica (context de Soniox). Se configura desde Provider Studio.
# MIRACLE_STT_DOMAIN=general              # general | medical
# MIRACLE_STT_SPECIALTY=general           # general|cardiologia|pediatria|ginecologia|dermatologia
# MIRACLE_STT_CUSTOM_TERMS=               # vocabulario propio, una palabra/término por línea

# --- Azure Foundry (opcional, reemplaza OpenRouter/OpenAI para dynamic fill y matching) ---
# Usa el endpoint OpenAI-compatible base, por ejemplo:
# AZURE_FOUNDRY_BASE_URL=https://christian-maldonadoor-0222-resou.services.ai.azure.com/openai/v1
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_MODEL=DeepSeek-V4-Flash

# --- Miracle sidecar (dictado/integracion medica externa) ---
# MIRACLE_MEDICAL_ENGINE_URL=http://127.0.0.1:8766
# MIRACLE_BASE_URL=http://127.0.0.1:8766
# En Vercel no hay fallback a Render. Si necesitas dictado Miracle externo,
# configura un motor HTTP propio y pasalo de forma explicita.
# Uso central IA: Miracle puede reportar consumo de OpenAI a Graph con esta clave compartida.
# GRAPH_USAGE_INGEST_KEY=

# --- Autenticacion (local, sin proveedor externo) ---
# Login de administrador para el dashboard/extension (usuario:usuario,otro:otro).
LOCAL_ADMIN_USERS=
LOCAL_ADMIN_PASSWORD=
# Secreto para firmar las sesiones de administrador. Si se omite, se genera uno
# aleatorio por proceso (las sesiones no sobreviven un reinicio del servidor).
LOCAL_ADMIN_SECRET=
# Modo invitado para paginas de demo publicas (sin login). Seguro de activar en
# produccion si quieres permitir acceso anonimo a las paginas de demo.
ALLOW_LOCAL_ANONYMOUS=false
# Bypass temporal y reversible para avanzar el desarrollo sin login.
# Mantenerlo en false por defecto y activarlo solo mientras se depura localmente.
TEMPORARY_DISABLE_AUTH=false
# Secreto compartido entre Node y el runtime Python (bounded/miracle-ai) para
# autenticar las llamadas internas al sidecar de voz/nota. Opcional en local.
GRAPH_INTERNAL_TOKEN=

# --- Servidor ---
NODE_ENV=development
PORT=3000
# PUBLIC_BASE_URL=   # URL pública si despliegas detrás de un dominio/túnel
# CORS: orígenes permitidos separados por coma. Vacío = permisivo (solo dev).
ALLOWED_ORIGINS=

# --- Workflows y administracion ---
GLOBAL_WORKFLOW_ADMIN_EMAILS=
ALLOW_LOCAL_GLOBAL_WORKFLOW_ADMIN=false

# ==========================================================================
# Modulo clinico (stateful, aislado en /api/clinical) — Supabase
# Solo aplica a /api/clinical/*. No afecta /api/v1 ni el resto del backend.
# ==========================================================================
# URL del proyecto Supabase (miracle-app). Requerida para el modulo clinico:
# se usa para verificar el JWT del profesional (JWKS) y para la persistencia.
SUPABASE_URL=
# Clave publishable/anon (para el frontend; el backend solo verifica JWT).
SUPABASE_ANON_KEY=
# SERVER-ONLY: usada por SupabaseRestClient para leer/escribir clinical_templates
# y clinical_encounters. NUNCA exponer al frontend ni reutilizar como token
# interno del sidecar (para eso esta GRAPH_INTERNAL_TOKEN).
SUPABASE_SERVICE_ROLE_KEY=
# Profesionales autorizados a gestionar plantillas INSTITUCIONALES (crear/editar/
# archivar). Listas separadas por coma; vacio = nadie (solo lectura institucional).
CLINICAL_ADMIN_EMAILS=
CLINICAL_ADMIN_USER_IDS=

# --- LLM del backend clinico (generate-note). Reusa el motor compartido. ---
# Provider principal via GRAPH_LLM_* (openai | openrouter | azure-foundry | disabled).
# Si no se define, cae a OPENAI_API_KEY / AZURE_FOUNDRY_* de arriba.
# GRAPH_LLM_PROVIDER=openai
# GRAPH_LLM_API_KEY=
# GRAPH_LLM_BASE_URL=
# GRAPH_LLM_MODEL=gpt-4o

# --- Biopsia / lectura de fotos de laboratorio (tarjeta Provider Studio "Biopsia") ---
# Provider de VISION propio, independiente del asistente y del field-matching.
# Se configura desde Provider Studio (escribe estas envs en Vercel y redeploya),
# o a mano aqui. Debe ser un modelo con vision: openai (recomendado) | google | disabled.
# MIRACLE_BIOPSY_LLM_PROVIDER=openai
# MIRACLE_BIOPSY_LLM_API_KEY=          # key activa que lee el runtime
# MIRACLE_BIOPSY_LLM_BASE_URL=https://api.openai.com/v1
# MIRACLE_BIOPSY_LLM_MODEL=gpt-4o
# Keys por-provider (recordadas al cambiar de provider y volver):
# MIRACLE_BIOPSY_LLM_OPENAI_API_KEY=
# MIRACLE_BIOPSY_LLM_GOOGLE_API_KEY=
