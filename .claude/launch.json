{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "miracle-static",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http'),fs=require('fs'),path=require('path');const root=path.join(process.cwd(),'web','public');const types={'.html':'text/html; charset=utf-8','.css':'text/css','.js':'text/javascript','.svg':'image/svg+xml','.png':'image/png','.jpg':'image/jpeg'};http.createServer((req,res)=>{let p=decodeURIComponent(req.url.split('?')[0]);if(p==='/')p='/index.html';const f=path.join(root,p);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('404');return;}res.writeHead(200,{'content-type':types[path.extname(f)]||'application/octet-stream'});res.end(d);});}).listen(4173,()=>console.log('Serving web/public on http://localhost:4173'));"
      ],
      "port": 4173
    },
    {
      "name": "miracle-server",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "web/server.js"
      ],
      "port": 3000
    }
  ]
}
